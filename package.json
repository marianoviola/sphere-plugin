{
  "name": "sphere-plugin",
  "version": "1.1.1",
  "private": false,
  "description": "Local Claude desktop extension (MCPB) for Sphere Fragment Intelligence and authoring, plus read-only client tools for a Sphere Node.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "pack": "npm run build && mcpb pack . dist/sphere-plugin.mcpb",
    "validate-manifest": "mcpb validate manifest.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^1.0.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "sharp": "^0.33.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
